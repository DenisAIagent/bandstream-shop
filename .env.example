# =============================================================================
# bandstream-shop — environment variables (NEVER commit real values)
# Copy this file to .env.local and fill in the values
# =============================================================================

# --- App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development

# URL absolue de la boutique pour SEO (sitemap, robots, canonical, OG, JSON-LD).
# Override en preview/staging. Défaut prod : https://shop.band.stream
NEXT_PUBLIC_SHOP_BASE_URL=http://localhost:3001

# --- Database (instance Postgres dédiée, distincte de bandstream-app)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/bandstream_shop?schema=public

# --- NextAuth
NEXTAUTH_URL=http://localhost:3001
# DÉPRÉCIÉ : l'auth est 100% custom (lib/auth.ts), NextAuth n'est pas utilisé.
# Conservé optionnel pour ne pas casser les déploiements existants.
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# --- Email (Resend) : magic links + emails transactionnels
# (confirmation / expédition / livraison / demande d'avis / remboursement,
#  relance abandon panier, factures, liens de téléchargement digitaux)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@band.stream

# --- Stripe Connect (Modèle A — Stripe gère les tarifs utilisateurs)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_CONNECT_CLIENT_ID=ca_xxxxx

# --- Google Merchant Center (Content API for Shopping)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/gmc/oauth/callback

# --- Meta Catalog (Facebook Graph API)
META_APP_ID=xxxxx
META_APP_SECRET=xxxxx
META_OAUTH_REDIRECT_URI=http://localhost:3001/api/meta/oauth/callback

# --- Encryption for OAuth tokens at rest (AES-GCM)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-32-bytes-base64

# --- Cron auth (relance abandon panier + demande d'avis post-livraison)
# Routes : /api/cron/abandoned-carts (*/30) et /api/cron/review-requests (1×/j)
# Envoyé en header `Authorization: Bearer <secret>` (Vercel Cron) ou `x-cron-secret`
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-strong-random

# --- Pricing (overridable for tests)
COMMISSION_RATE_PRO=0.03
COMMISSION_RATE_LABEL=0.00
COMMISSION_FLOOR_CENTS_PRO=30
COMMISSION_FLOOR_CENTS_LABEL=0

# SSO depuis l'app principale band.stream (bandstream-app) — même valeur des deux côtés
SHOP_SSO_SECRET=
