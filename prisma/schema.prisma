// bandstream-shop — Prisma schema (instance Postgres dédiée, distincte de bandstream-app)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum Tier {
  PRO
  LABEL
}

enum ArtistStatus {
  ACTIVE
  VACATION
  SUSPENDED
  CLOSED
}

enum KycStatus {
  PENDING
  ACTIVE
  RESTRICTED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PAID
  SHIPPED
  DELIVERED
  REFUNDED
  CANCELLED
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  ERROR
}

// =============================================================================
// Identity & shop
// =============================================================================

model ShopArtist {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String
  artistName    String
  slug          String       @unique
  tier          Tier         @default(PRO)
  countryCode   String
  status        ArtistStatus @default(ACTIVE)
  vacationUntil DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  shop          Shop?
  stripeAccount StripeConnectAccount?
  sessions      ArtistSession[]

  @@index([slug])
  @@index([email])
}

model ArtistSession {
  id        String     @id @default(cuid())
  artistId  String
  artist    ShopArtist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  token     String     @unique
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([token])
  @@index([artistId])
}

model Shop {
  id              String           @id @default(cuid())
  artistId        String           @unique
  artist          ShopArtist       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  displayName     String
  description     String?
  logoUrl         String?
  contactEmail    String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  shippingZones   ShippingZone[]
  products        Product[]
  orders          Order[]
  gmcIntegration  GmcIntegration?
  metaIntegration MetaIntegration?
}

model StripeConnectAccount {
  id              String     @id @default(cuid())
  artistId        String     @unique
  artist          ShopArtist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  stripeAccountId String     @unique
  kycStatus       KycStatus  @default(PENDING)
  payoutsEnabled  Boolean    @default(false)
  chargesEnabled  Boolean    @default(false)
  detailsSubmitted Boolean   @default(false)
  updatedAt       DateTime   @updatedAt
  createdAt       DateTime   @default(now())
}

// =============================================================================
// Catalog
// =============================================================================

model Product {
  id             String           @id @default(cuid())
  shopId         String
  shop           Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  slug           String
  title          String
  shortDesc      String
  longDesc       String
  category       String
  brand          String
  status         ProductStatus    @default(DRAFT)
  basePriceCents Int
  weightGrams    Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  images         ProductImage[]
  variants       ProductVariant[]
  orderItems     OrderItem[]

  @@unique([shopId, slug])
  @@index([status])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku        String
  size       String?
  color      String?
  stock      Int         @default(0)
  priceCents Int
  orderItems OrderItem[]

  @@unique([productId, sku])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  position  Int     @default(0)
  isPrimary Boolean @default(false)
}

// =============================================================================
// Shipping
// =============================================================================

model ShippingZone {
  id             String   @id @default(cuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name           String
  countries      String[] // ISO-2 codes
  flatRateCents  Int
  freeAboveCents Int?
  estimatedDays  Int
  carrier        String
  enabled        Boolean  @default(true)
}

// =============================================================================
// Orders
// =============================================================================

model Order {
  id                    String      @id @default(cuid())
  publicNumber          String      @unique
  shopId                String
  shop                  Shop        @relation(fields: [shopId], references: [id])
  fanEmail              String
  fanName               String
  shippingAddress       Json
  billingAddress        Json?
  subtotalCents         Int
  shippingCents         Int
  totalCents            Int
  currency              String      @default("EUR")
  stripePaymentIntentId String      @unique
  stripeChargeId        String?
  applicationFeeCents   Int
  stripeFeeCents        Int?
  status                OrderStatus @default(PAID)
  carrier               String?
  trackingNumber        String?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  refundedAt            DateTime?
  refundedAmountCents   Int?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  items OrderItem[]

  @@index([shopId, status])
  @@index([fanEmail])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  titleSnapshot   String
  variantSnapshot String?
  unitPriceCents  Int
  quantity        Int
}

// =============================================================================
// External catalog integrations
// =============================================================================

model GmcIntegration {
  id           String            @id @default(cuid())
  shopId       String            @unique
  shop         Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  merchantId   String
  refreshToken String // chiffré au repos (AES-GCM)
  status       IntegrationStatus @default(PENDING)
  lastSyncAt   DateTime?
  lastError    String?
  updatedAt    DateTime          @updatedAt
  createdAt    DateTime          @default(now())
}

model MetaIntegration {
  id          String            @id @default(cuid())
  shopId      String            @unique
  shop        Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  businessId  String
  catalogId   String
  accessToken String // long-lived, chiffré au repos
  status      IntegrationStatus @default(PENDING)
  lastSyncAt  DateTime?
  lastError   String?
  updatedAt   DateTime          @updatedAt
  createdAt   DateTime          @default(now())
}
